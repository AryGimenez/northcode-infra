# /stagnig/production/.env

# Configuración General
TZ=America/Montevideo # Zona horaria
PUID=1000 # Identificador de usuario
PGID=1000 # Identificador de grupo

# DuckDNS
DUCKDNS_TOKEN=5e7abc96-9942-4108-9080-2cb1e116e9f8 # Token de DuckDNS
DUCKDNS_SUBDOMAINS=northcodeuy # Nombre del subdominio

# Wireguard
WG_SERVERURL=${DUCKDNS_SUBDOMAINS}.duckdns.org # Nombre del dominio al que apunta en caso de no tener ip publica
WG_PEERS=ary_cel,ary_notebook # Por cada nombre separado por coma. Wireguard genera un los archivos de configuracion de los clientes 
WG_SERVERPORT=51820 # Puerto del servicio este es el que tenes que abrir en el router
